<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.StudyPlanMapper">
    
    <resultMap type="StudyPlan" id="StudyPlanResult">
        <result property="planId"    column="plan_id"    />
        <result property="userId"    column="user_id"    />
        <result property="planName"    column="plan_name"    />
        <result property="planType"    column="plan_type"    />
        <result property="parentPlanId"    column="parent_plan_id"    />
        <result property="startDate"    column="start_date"    />
        <result property="endDate"    column="end_date"    />
        <result property="deadline"    column="deadline"    />
        <result property="priority"    column="priority"    />
        <result property="difficulty"    column="difficulty"    />
        <result property="tags"    column="tags"    />
        <result property="subject"    column="subject"    />
        <result property="description"    column="description"    />
        <result property="learningGoals"    column="learning_goals"    />
        <result property="estimatedHours"    column="estimated_hours"    />
        <result property="actualHours"    column="actual_hours"    />
        <result property="progress"    column="progress"    />
        <result property="totalTasks"    column="total_tasks"    />
        <result property="completedTasks"    column="completed_tasks"    />
        <result property="status"    column="status"    />
        <result property="isTemplate"    column="is_template"    />
        <result property="isCompleted"    column="is_completed"    />
        <result property="completedTime"    column="completed_time"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectStudyPlanVo">
        select plan_id, user_id, plan_name, plan_type, parent_plan_id, start_date, end_date, deadline, priority, difficulty, tags, subject, description, learning_goals, estimated_hours, actual_hours, progress, total_tasks, completed_tasks, status, is_template, is_completed, completed_time, create_time, update_time from study_plan
    </sql>

    <select id="selectStudyPlanList" parameterType="StudyPlan" resultMap="StudyPlanResult">
        <include refid="selectStudyPlanVo"/>
        <where>  
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="planName != null  and planName != ''"> and plan_name like concat('%', #{planName}, '%')</if>
            <if test="planType != null  and planType != ''"> and plan_type = #{planType}</if>
            <if test="planType == 'today' and parentPlanId == null"> and start_date = CURDATE()</if>
            <if test="parentPlanId != null "> and parent_plan_id = #{parentPlanId}</if>
            <if test="startDate != null "> and start_date = #{startDate}</if>
            <if test="endDate != null "> and end_date = #{endDate}</if>
            <if test="deadline != null "> and deadline = #{deadline}</if>
            <if test="priority != null "> and priority = #{priority}</if>
            <if test="difficulty != null "> and difficulty = #{difficulty}</if>
            <if test="tags != null  and tags != ''"> and tags = #{tags}</if>
            <if test="subject != null  and subject != ''"> and subject = #{subject}</if>
            <if test="description != null  and description != ''"> and description = #{description}</if>
            <if test="learningGoals != null  and learningGoals != ''"> and learning_goals = #{learningGoals}</if>
            <if test="progress != null "> and progress = #{progress}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="isTemplate != null "> and is_template = #{isTemplate}</if>
            <if test="isCompleted != null "> and is_completed = #{isCompleted}</if>
            <if test="completedTime != null "> and completed_time = #{completedTime}</if>
            <if test="estimatedHours != null "> and estimated_hours = #{estimatedHours}</if>
            <if test="actualHours != null "> and actual_hours = #{actualHours}</if>
        </where>
        order by create_time desc
    </select>
    
    <select id="selectStudyPlanByPlanId" parameterType="Long" resultMap="StudyPlanResult">
        <include refid="selectStudyPlanVo"/>
        where plan_id = #{planId}
    </select>
        
    <insert id="insertStudyPlan" parameterType="StudyPlan" useGeneratedKeys="true" keyProperty="planId">
        insert into study_plan
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="planName != null and planName != ''">plan_name,</if>
            <if test="planType != null and planType != ''">plan_type,</if>
            <if test="parentPlanId != null">parent_plan_id,</if>
            <if test="startDate != null">start_date,</if>
            <if test="endDate != null">end_date,</if>
            <if test="deadline != null">deadline,</if>
            <if test="priority != null">priority,</if>
            <if test="difficulty != null">difficulty,</if>
            <if test="tags != null">tags,</if>
            <if test="subject != null">subject,</if>
            <if test="description != null">description,</if>
            <if test="learningGoals != null">learning_goals,</if>
            <if test="estimatedHours != null">estimated_hours,</if>
            <if test="actualHours != null">actual_hours,</if>
            <if test="progress != null">progress,</if>
            <if test="totalTasks != null">total_tasks,</if>
            <if test="completedTasks != null">completed_tasks,</if>
            <if test="status != null">status,</if>
            <if test="isTemplate != null">is_template,</if>
            <if test="isCompleted != null">is_completed,</if>
            <if test="completedTime != null">completed_time,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="planName != null and planName != ''">#{planName},</if>
            <if test="planType != null and planType != ''">#{planType},</if>
            <if test="parentPlanId != null">#{parentPlanId},</if>
            <if test="startDate != null">#{startDate},</if>
            <if test="endDate != null">#{endDate},</if>
            <if test="deadline != null">#{deadline},</if>
            <if test="priority != null">#{priority},</if>
            <if test="difficulty != null">#{difficulty},</if>
            <if test="tags != null">#{tags},</if>
            <if test="subject != null">#{subject},</if>
            <if test="description != null">#{description},</if>
            <if test="learningGoals != null">#{learningGoals},</if>
            <if test="estimatedHours != null">#{estimatedHours},</if>
            <if test="actualHours != null">#{actualHours},</if>
            <if test="progress != null">#{progress},</if>
            <if test="totalTasks != null">#{totalTasks},</if>
            <if test="completedTasks != null">#{completedTasks},</if>
            <if test="status != null">#{status},</if>
            <if test="isTemplate != null">#{isTemplate},</if>
            <if test="isCompleted != null">#{isCompleted},</if>
            <if test="completedTime != null">#{completedTime},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateStudyPlan" parameterType="StudyPlan">
        update study_plan
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null">user_id = #{userId},</if>
            <if test="planName != null and planName != ''">plan_name = #{planName},</if>
            <if test="planType != null and planType != ''">plan_type = #{planType},</if>
            <if test="parentPlanId != null">parent_plan_id = #{parentPlanId},</if>
            <if test="startDate != null">start_date = #{startDate},</if>
            <if test="endDate != null">end_date = #{endDate},</if>
            <if test="deadline != null">deadline = #{deadline},</if>
            <if test="priority != null">priority = #{priority},</if>
            <if test="difficulty != null">difficulty = #{difficulty},</if>
            <if test="tags != null">tags = #{tags},</if>
            <if test="subject != null">subject = #{subject},</if>
            <if test="description != null">description = #{description},</if>
            <if test="learningGoals != null">learning_goals = #{learningGoals},</if>
            <if test="estimatedHours != null">estimated_hours = #{estimatedHours},</if>
            <if test="actualHours != null">actual_hours = #{actualHours},</if>
            <if test="progress != null">progress = #{progress},</if>
            <if test="totalTasks != null">total_tasks = #{totalTasks},</if>
            <if test="completedTasks != null">completed_tasks = #{completedTasks},</if>
            <if test="status != null">status = #{status},</if>
            <if test="isTemplate != null">is_template = #{isTemplate},</if>
            <if test="isCompleted != null">is_completed = #{isCompleted},</if>
            <if test="completedTime != null">completed_time = #{completedTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where plan_id = #{planId}
    </update>

    <delete id="deleteStudyPlanByPlanId" parameterType="Long">
        delete from study_plan where plan_id = #{planId}
    </delete>

    <delete id="deleteStudyPlanByPlanIds" parameterType="String">
        delete from study_plan where plan_id in 
        <foreach item="planId" collection="array" open="(" separator="," close=")">
            #{planId}
        </foreach>
    </delete>
    
    <select id="selectStudyPlanByUserId" parameterType="Long" resultMap="StudyPlanResult">
        <include refid="selectStudyPlanVo"/>
        where user_id = #{userId}
        order by create_time desc
    </select>
    
    <select id="selectTodayStudyPlanByUserId" parameterType="Long" resultMap="StudyPlanResult">
        <include refid="selectStudyPlanVo"/>
        where user_id = #{userId} 
        and date(create_time) = curdate()
        order by create_time desc
    </select>
    
    <select id="countCompletedPlansByUserId" parameterType="Long" resultType="int">
        select count(*) from study_plan 
        where user_id = #{userId} and is_completed = 1
    </select>
</mapper>